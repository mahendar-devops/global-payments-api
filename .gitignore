# ─────────────────────────────────────────────────────────────────
# .gitignore — Global (root-level)
# Covers all three microservices and the infra/ Terraform directory.
# ─────────────────────────────────────────────────────────────────

# ── SECRETS — NEVER COMMIT ───────────────────────────────────────
*.env
.env.*
!.env.example          # Example files are safe to commit
*.pem
*.key
*_rsa
*secret*
*credentials*
kubeconfig
.kube/

# ── Java / Maven ─────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
!**/src/main/**/target/
!**/src/test/**/target/

# ── Node.js ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
.yarn/
coverage/
.nyc_output/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
.env/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
*.pyc

# ── Terraform ────────────────────────────────────────────────────
**/.terraform/
*.tfstate          # State files contain sensitive data — managed in S3
*.tfstate.*
*.tfplan
*.tfplan.binary
tfplan.binary
.terraform.lock.hcl.bak

# terraform.tfvars may contain secrets — exclude by default
# (only non-sensitive .tfvars should be committed)
# terraform.tfvars       ← We DO commit these (they have no secrets)
*.auto.tfvars          # Auto-loaded var files may have secrets — exclude

# ── Docker ───────────────────────────────────────────────────────
*.tar

# ── IDE ──────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.vscode/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log
yarn-error.log

# ── Test Artifacts ────────────────────────────────────────────────
*.sarif               # Trivy SARIF output (generated by pipeline)
dependency-check-report.xml
