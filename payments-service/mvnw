#!/bin/sh
# Maven Wrapper Script — auto-downloads Maven if not present
# Do not edit this file. Generated by Spring Initializr.
set -e
MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

if [ -r "$MAVEN_WRAPPER_PROPERTIES" ]; then
  DISTRIBUTION_URL=$(grep distributionUrl "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
fi

MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_HOME="${MAVEN_USER_HOME}/wrapper/dists/$(basename "$DISTRIBUTION_URL" .zip)"

if [ ! -d "$MAVEN_HOME" ]; then
  mkdir -p "$MAVEN_HOME"
  echo "Downloading Maven from $DISTRIBUTION_URL"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$DISTRIBUTION_URL" -o "/tmp/maven.zip"
  else
    wget -q "$DISTRIBUTION_URL" -O "/tmp/maven.zip"
  fi
  unzip -q "/tmp/maven.zip" -d "$MAVEN_HOME"
  rm "/tmp/maven.zip"
fi

MAVEN_EXEC=$(find "$MAVEN_HOME" -name "mvn" -type f | head -1)
exec "$MAVEN_EXEC" "$@"
