// payments-service/Jenkinsfile
// Java Spring Boot Payments Service — Free-Tier EC2 CI/CD Pipeline
// Deploys to App Server EC2 via SSH + Docker.
//
// Jenkins Credentials required:
//   app-server-ssh-key → SSH private key (kind: SSH Username with private key)
//   app-server-ip      → App server public IP (kind: Secret text)
//   sonarqube-token    → SonarQube token (kind: Secret text)

pipeline {
    agent any

    environment {
        APP_NAME    = 'payments-service'
        IMAGE_TAG   = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        APP_SERVER  = credentials('app-server-ip')
        SONAR_TOKEN = credentials('sonarqube-token')
        // Tell Maven to use at most 512MB heap — critical on t2.micro
        MAVEN_OPTS  = '-Xmx512m -Xms256m'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Unit Test') {
            steps {
                dir('payments-service') {
                    sh '''
                        # Ensure mvnw is executable
                        chmod +x ./mvnw

                        # Run tests and generate coverage report
                        # -B = batch mode (no progress bars)
                        # -q = quiet (less output, saves memory)
                        ./mvnw clean verify -B -q \
                          -Dmaven.test.failure.ignore=false \
                          -DforkCount=1 \
                          -DreuseForks=true
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'payments-service/target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube') {
            steps {
                dir('payments-service') {
                    sh """
                        ./mvnw sonar:sonar -B -q \
                          -Dsonar.projectKey=payments-service \
                          -Dsonar.host.url=http://localhost:9000 \
                          -Dsonar.login=${SONAR_TOKEN} \
                          -Dsonar.qualitygate.wait=false
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('payments-service') {
                    sh """
                        docker build \
                          --build-arg BUILD_VERSION=${IMAGE_TAG} \
                          --build-arg GIT_COMMIT=${GIT_COMMIT} \
                          -t ${APP_NAME}:${IMAGE_TAG} \
                          -t ${APP_NAME}:latest \
                          .
                    """
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                sh """
                    trivy image \
                      --exit-code 1 \
                      --severity CRITICAL,HIGH \
                      --timeout 10m \
                      --format table \
                      ${APP_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Deploy') {
            when { branch 'main' }
            steps {
                sshagent(['app-server-ssh-key']) {
                    sh """
                        echo "Saving Docker image..."
                        docker save ${APP_NAME}:${IMAGE_TAG} | gzip > /tmp/${APP_NAME}.tar.gz

                        echo "Transferring to app server..."
                        scp -o StrictHostKeyChecking=no \
                          /tmp/${APP_NAME}.tar.gz \
                          ec2-user@${APP_SERVER}:/tmp/

                        echo "Deploying on app server..."
                        ssh -o StrictHostKeyChecking=no ec2-user@${APP_SERVER} '
                          set -e
                          docker load < /tmp/${APP_NAME}.tar.gz
                          docker stop payments-service 2>/dev/null || true
                          docker rm   payments-service 2>/dev/null || true
                          docker run -d \
                            --name payments-service \
                            --restart unless-stopped \
                            --network global-payments-api_payments-net \
                            -p 8080:8080 \
                            -e SPRING_PROFILES_ACTIVE=production \
                            -e DB_URL=jdbc:postgresql://postgres:5432/payments \
                            -e DB_USERNAME=payments_user \
                            -e DB_PASSWORD=$(cat ~/global-payments-api/.env | grep DB_PASSWORD | cut -d= -f2) \
                            -e JWT_SECRET=$(cat ~/global-payments-api/.env | grep JWT_SECRET | cut -d= -f2) \
                            -e KAFKA_BOOTSTRAP_SERVERS=kafka:9092 \
                            ${APP_NAME}:${IMAGE_TAG}
                          rm -f /tmp/${APP_NAME}.tar.gz
                          echo "✅ payments-service deployed"
                        '
                        rm -f /tmp/${APP_NAME}.tar.gz
                    """
                }
            }
        }

        stage('Smoke Test') {
            when { branch 'main' }
            steps {
                sh """
                    echo "Waiting 60 seconds for Spring Boot startup..."
                    sleep 60
                    STATUS=\$(curl -sf -o /dev/null -w '%{http_code}' \
                      http://${APP_SERVER}:8080/actuator/health || echo 000)
                    echo "Health check: HTTP \$STATUS"
                    [ "\$STATUS" = "200" ] && echo "✅ payments-service healthy" || { echo "❌ Health check failed"; exit 1; }
                """
            }
        }
    }

    post {
        always {
            sh "docker rmi ${APP_NAME}:${IMAGE_TAG} 2>/dev/null || true; docker image prune -f || true"
        }
        success { echo "✅ ${APP_NAME} deployed successfully — ${IMAGE_TAG}" }
        failure { echo "❌ ${APP_NAME} pipeline FAILED — Stage: ${env.STAGE_NAME}" }
    }
}
