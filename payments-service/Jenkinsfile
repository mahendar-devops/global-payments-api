// payments-service/Jenkinsfile — Free Tier EC2 Edition
pipeline {
    agent any

    environment {
        APP_NAME    = 'payments-service'
        IMAGE_TAG   = "${BUILD_NUMBER}-${GIT_COMMIT[0..7]}"
        SONAR_TOKEN = credentials('sonarqube-token')
        APP_SERVER  = credentials('app-server-ip')
        SSH_KEY     = credentials('app-server-ssh-key')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log -1 --pretty=format:"%h %s" > .git/commit-msg'
                script { env.COMMIT_MSG = readFile('.git/commit-msg').trim() }
            }
        }

        stage('Build & Unit Test') {
            steps {
                dir('payments-service') {
                    sh './mvnw clean verify -B -q -Dspring.main.allow-bean-definition-overriding=true'
                }
            }
            post { always { junit 'payments-service/target/surefire-reports/*.xml' } }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('payments-service') {
                    sh """
                        ./mvnw sonar:sonar \
                          -Dsonar.projectKey=payments-service \
                          -Dsonar.host.url=http://localhost:9000 \
                          -Dsonar.login=${SONAR_TOKEN} \
                          -B -q
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('payments-service') {
                    sh "docker build -t ${APP_NAME}:${IMAGE_TAG} -t ${APP_NAME}:latest ."
                }
            }
        }

        stage('Trivy Security Scan') {
            steps {
                sh """
                    # Install Trivy if not present
                    which trivy || curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin

                    # Scan image — fail on CRITICAL or HIGH vulnerabilities
                    trivy image \
                      --exit-code 1 \
                      --severity CRITICAL,HIGH \
                      --format table \
                      ${APP_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Deploy to App Server') {
            when { branch 'main' }
            steps {
                script {
                    // Save Docker image to a tar file
                    sh "docker save ${APP_NAME}:${IMAGE_TAG} | gzip > ${APP_NAME}-${IMAGE_TAG}.tar.gz"

                    // Copy image to app server via SSH
                    sh """
                        scp -i ${SSH_KEY} -o StrictHostKeyChecking=no \
                          ${APP_NAME}-${IMAGE_TAG}.tar.gz \
                          ec2-user@${APP_SERVER}:/tmp/
                    """

                    // Load image and restart container on app server
                    sh """
                        ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ec2-user@${APP_SERVER} '
                          docker load < /tmp/${APP_NAME}-${IMAGE_TAG}.tar.gz && \
                          docker stop ${APP_NAME} 2>/dev/null || true && \
                          docker rm ${APP_NAME} 2>/dev/null || true && \
                          docker run -d \
                            --name ${APP_NAME} \
                            --restart unless-stopped \
                            -p 8080:8080 \
                            -e SPRING_PROFILES_ACTIVE=production \
                            ${APP_NAME}:${IMAGE_TAG} && \
                          echo "Deployed successfully!"
                        '
                    """

                    // Cleanup
                    sh "rm -f ${APP_NAME}-${IMAGE_TAG}.tar.gz"
                }
            }
        }

        stage('Smoke Test') {
            when { branch 'main' }
            steps {
                sh """
                    sleep 30  # Wait for Spring Boot to start
                    STATUS=\$(curl -sf -o /dev/null -w "%{http_code}" \
                      http://${APP_SERVER}:8080/actuator/health 2>/dev/null || echo "000")
                    echo "Health check: HTTP \$STATUS"
                    [ "\$STATUS" = "200" ] || exit 1
                """
            }
        }
    }

    post {
        success { echo "✅ Pipeline PASSED: ${env.COMMIT_MSG}" }
        failure { echo "❌ Pipeline FAILED at stage: ${env.STAGE_NAME}" }
    }
}
