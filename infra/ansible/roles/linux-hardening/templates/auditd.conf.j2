# {{ ansible_managed }}
# /etc/audit/auditd.conf — Managed by Ansible linux-hardening role
# Regenerated on: {{ ansible_date_time.iso8601 }}

log_file = /var/log/audit/audit.log
log_format = ENRICHED
log_group = root
priority_boost = 4
flush = INCREMENTAL_ASYNC
freq = 50
max_log_file = {{ auditd_max_log_file }}
max_log_file_action = {{ auditd_max_log_file_action }}
num_logs = {{ auditd_num_logs }}
space_left = 75
space_left_action = SYSLOG
admin_space_left = 50
admin_space_left_action = HALT     # Halt system if disk space critically low (compliance)
disk_full_action = HALT
disk_error_action = SYSLOG
use_libwrap = yes
tcp_listen_queue = 5
tcp_max_per_addr = 1
tcp_client_max_idle = 0
enable_krb5 = no
krb5_principal = auditd
distribute_network = no
