# data-processing-service — Environment Variables
# Copy to .env for local development.
# In Kubernetes: injected via AWS Secrets Manager + Secrets Store CSI Driver.
# NEVER commit a populated .env file to Git.

FLASK_ENV=development
PORT=5000
ENVIRONMENT=local

# Database (reporting replica — separate from payments-service DB)
DATABASE_URL=postgresql://reporting_user:localpassword@localhost:5433/payments_reporting

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AWS (use real values or LocalStack for local development)
AWS_REGION=eu-west-2
S3_REPORTS_BUCKET=payments-reports-local

# Reconciliation tuning
RECON_BATCH_SIZE=1000
RECON_LOOKBACK_DAYS=2

# Logging
LOG_LEVEL=DEBUG
