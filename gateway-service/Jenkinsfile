// gateway-service/Jenkinsfile
// Node.js API Gateway — Free-Tier EC2 CI/CD Pipeline
// Deploys to App Server EC2 via SSH + Docker.
//
// Jenkins Credentials required:
//   app-server-ssh-key → SSH private key (kind: SSH Username with private key)
//   app-server-ip      → App server public IP (kind: Secret text)
//   sonarqube-token    → SonarQube token (kind: Secret text)

pipeline {
    agent any

    environment {
        APP_NAME    = 'gateway-service'
        IMAGE_TAG   = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        APP_SERVER  = credentials('app-server-ip')
        SONAR_TOKEN = credentials('sonarqube-token')
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_AUTHOR = sh(script: "git log -1 --pretty=format:'%an'", returnStdout: true).trim()
                }
            }
        }

        stage('Install & Test') {
            steps {
                dir('gateway-service') {
                    sh '''
                        node --version
                        npm --version
                        npm ci
                        npm test -- --coverage --forceExit
                    '''
                }
            }
        }

        stage('SonarQube') {
            steps {
                dir('gateway-service') {
                    sh """
                        npm install -g sonar-scanner --quiet 2>/dev/null || true
                        sonar-scanner \
                          -Dsonar.projectKey=gateway-service \
                          -Dsonar.sources=src \
                          -Dsonar.exclusions=node_modules/**,coverage/** \
                          -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                          -Dsonar.host.url=http://localhost:9000 \
                          -Dsonar.login=${SONAR_TOKEN} || true
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('gateway-service') {
                    sh "docker build -t ${APP_NAME}:${IMAGE_TAG} -t ${APP_NAME}:latest ."
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                sh """
                    trivy image --exit-code 1 --severity CRITICAL,HIGH \
                      --timeout 5m --format table ${APP_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Deploy') {
            when { branch 'main' }
            steps {
                sshagent(['app-server-ssh-key']) {
                    sh """
                        docker save ${APP_NAME}:${IMAGE_TAG} | gzip > /tmp/${APP_NAME}.tar.gz
                        scp -o StrictHostKeyChecking=no /tmp/${APP_NAME}.tar.gz ec2-user@${APP_SERVER}:/tmp/
                        ssh -o StrictHostKeyChecking=no ec2-user@${APP_SERVER} '
                          docker load < /tmp/${APP_NAME}.tar.gz &&
                          docker stop ${APP_NAME} 2>/dev/null || true &&
                          docker rm   ${APP_NAME} 2>/dev/null || true &&
                          docker run -d --name ${APP_NAME} --restart unless-stopped \
                            --network global-payments-api_payments-net \
                            -p 3000:3000 \
                            -e NODE_ENV=production \
                            -e PAYMENTS_SERVICE_URL=http://payments-service:8080 \
                            ${APP_NAME}:${IMAGE_TAG} &&
                          rm -f /tmp/${APP_NAME}.tar.gz &&
                          echo "✅ Deployed ${APP_NAME}:${IMAGE_TAG}"
                        '
                        rm -f /tmp/${APP_NAME}.tar.gz
                    """
                }
            }
        }

        stage('Smoke Test') {
            when { branch 'main' }
            steps {
                sh """
                    sleep 15
                    STATUS=\$(curl -sf -o /dev/null -w '%{http_code}' http://${APP_SERVER}:3000/health/liveness || echo 000)
                    [ "\$STATUS" = "200" ] && echo "✅ Smoke test passed" || { echo "❌ Smoke test failed: \$STATUS"; exit 1; }
                """
            }
        }
    }

    post {
        always {
            sh "docker rmi ${APP_NAME}:${IMAGE_TAG} 2>/dev/null || true; docker image prune -f || true"
        }
        success { echo "✅ ${APP_NAME} deployed successfully — ${IMAGE_TAG}" }
        failure { echo "❌ ${APP_NAME} pipeline failed at: ${env.STAGE_NAME}" }
    }
}
