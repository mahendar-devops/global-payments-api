{
  "env": {
    "node": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-console":         ["warn", { "allow": ["warn", "error"] }],
    "no-unused-vars":     ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-var":             "error",
    "prefer-const":       "error",
    "eqeqeq":             ["error", "always"],
    "curly":              ["error", "all"],
    "no-throw-literal":   "error",
    "handle-callback-err":"error",
    "no-process-exit":    "warn",
    "strict":             ["error", "global"]
  }
}
